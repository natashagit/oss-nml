# deploy/Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install dependencies (fastapi, uvicorn, prometheus, etc)
RUN pip install --no-cache-dir fastapi uvicorn prometheus-fastapi-instrumentator openai httpx

# Copy the source code from the project root
COPY src/ ./src/

# CRITICAL: This allows 'from ai_api import...' to work
ENV PYTHONPATH="${PYTHONPATH}:/app/src"

# Default Command
CMD ["uvicorn", "ai_service.main:app", "--host", "0.0.0.0", "--port", "8000"]