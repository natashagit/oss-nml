# Gmail Configuration
GMAIL_ACCESS_TOKEN=your-access-token
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_SCOPES=https://mail.google.com/
GMAIL_UNIVERSE_DOMAIN=googleapis.com
GMAIL_ACCOUNT=
GMAIL_TOKEN_EXPIRY=YYYY-MM-DDTHH:MM:SSZ

# AI Ticket Service - Common Configuration
OPENAI_API_KEY=your-openai-api-key
TICKET_BACKEND=google_tasks

# AI Ticket Service - Google Tasks Backend
TASKS_CLIENT_ID=your-client-id.apps.googleusercontent.com
TASKS_CLIENT_SECRET=your-client-secret
TASKS_REFRESH_TOKEN=your-refresh-token
TASKS_TOKEN_URI=https://oauth2.googleapis.com/token
TASKS_INTERACTIVE=false

# AI Ticket Service - Trello Backend
TRELLO_API_KEY=your-trello-api-key
TRELLO_API_SECRET=your-trello-api-secret
TRELLO_TOKEN=your-trello-token
TRELLO_BOARD_ID=your-board-id
REDIRECT_URI=http://localhost:8000/callback

# Discord Integration
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_DEFAULT_TOKEN_TYPE=Bot
CHAT_CHANNEL_ID=your-discord-channel-id
